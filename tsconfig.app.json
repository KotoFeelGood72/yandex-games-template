{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": [
    "src/**/__tests__/*",
    "src/game/systems/WeaponSystem.ts",
    "src/game/systems/AutoAimSystem.ts",
    "src/game/systems/BossSystem.ts",
    "src/game/systems/CollisionSystem.ts",
    "src/game/systems/DamageSystem.ts",
    "src/game/systems/EnemyBehaviorSystem.ts",
    "src/game/systems/EnemySpawnerSystem.ts",
    "src/game/systems/HeroPassiveSystem.ts",
    "src/game/systems/MissionSystem.ts",
    "src/game/systems/OrbitalBladesSystem.ts",
    "src/game/systems/SecondaryWeaponSystem.ts",
    "src/game/systems/TurretSystem.ts",
    "src/game/systems/WaveSystem.ts",
    "src/game/systems/XPSystem.ts",
    "src/game/systems/DevourerHazardSystem.ts",
    "src/game/domain/applyRunBonuses.ts",
    "src/stores/playerStore.ts",
    "src/stores/gameStore.ts",
    "src/stores/runStore.ts",
    "src/ui/components/UpgradeModal.vue",
    "src/ui/components/GameOverModal.vue",
    "src/ui/components/GameEventModal.vue",
    "src/game/data/upgradesConfig.ts",
  ],
  "compilerOptions": {
    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
